<% if @product.image.attached? %>
  <%= image_tag @product.image, width: 400 %>
<% end %>
<h1><%= @product.name %></h1>
<p><%= @product.category.name if @product.category %></p>
<p>$<%= @product.price %></p>
<p><%= @product.description %></p>
<p>Stock: <%= @product.stock %></p>
<%= link_to "Back to Products", products_path %>
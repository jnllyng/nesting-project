<div class="product-card">
  <%= link_to product_path(product) do %>
    <% if product.image.attached? %>
      <%= image_tag product.image.variant(:thumb) %>
    <% elsif product.image_url.present? %>
      <%= image_tag product.image_url %>
    <% else %>
      <div class="placeholder-img"></div>
    <% end %>
    <p style="font-size: 0.75rem; letter-spacing: 0.05em; text-transform: uppercase; color: #999; margin-bottom: 4px;">
      <%= product.categories.map(&:name).join(", ") if product.categories.any? %>
    </p>
    <h3><%= product.name.upcase %></h3>
    <p class="price">$<%= number_with_precision(product.price, precision: 2) %></p>
  <% end %>
</div>
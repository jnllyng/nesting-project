<h1>Account Settings</h1>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
  <% if resource.errors.any? %>
    <div style="margin-bottom: 20px; padding: 12px 16px; border: 1px solid #cc0000; background: #fff5f5;">
      <% resource.errors.full_messages.each do |msg| %>
        <p style="font-size: 0.8rem; color: #cc0000; margin: 0;">← <%= msg %></p>
      <% end %>
    </div>
  <% end %>

  <div style="margin-bottom: 20px;">
    <%= f.label :first_name, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.text_field :first_name, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :last_name, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.text_field :last_name, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :email, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.email_field :email, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :password, "New Password (leave blank to keep current)", style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.password_field :password, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :current_password, "Current Password (required to save changes)", style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.password_field :current_password, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>
  <div style="margin-bottom: 20px;">
  <%= f.label :province_id, "Province (optional)", style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
  <%= f.select :province_id, Province.all.order(:name).map { |p| [p.name, p.id] }, { prompt: "Select Province", selected: current_user.province_id }, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
</div>
  <%= f.submit "Save Changes", style: "padding: 12px 30px; background: #111; color: #fff; border: none; font-family: inherit; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;" %>
<% end %>

<div style="margin-top: 30px; padding-top: 20px; border-top: 1px solid #eee;">
  <%= button_to "Delete Account", registration_path(resource_name), data: { confirm: "Are you sure?" }, method: :delete, style: "background: none; border: none; font-size: 0.8rem; color: #999; text-decoration: underline; cursor: pointer;" %>
</div>

<div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid #eee;">
  <h2 style="font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 20px;">Saved Addresses</h2>

  <% current_user.addresses.each do |address| %>
    <div style="display: flex; justify-content: space-between; align-items: center; padding: 12px 0; border-bottom: 1px solid #eee; font-size: 0.85rem;">
      <span><%= address.street %>, <%= address.city %>, <%= address.postal_code %>, <%= address.province.name %></span>
      <%= button_to "Remove", address_path(address), method: :delete, style: "background: none; border: none; font-size: 0.75rem; text-decoration: underline; cursor: pointer; color: #999;" %>
    </div>
  <% end %>

  <h3 style="font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 20px; margin-bottom: 15px;">Add New Address</h3>

  <%= form_with url: addresses_path, method: :post, local: true do |f| %>
    <div style="margin-bottom: 15px;">
      <label style="display: block; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px;">Street</label>
      <input type="text" name="address[street]" style="width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem; box-sizing: border-box;">
    </div>
    <div style="margin-bottom: 15px;">
      <label style="display: block; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px;">City</label>
      <input type="text" name="address[city]" style="width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem; box-sizing: border-box;">
    </div>
    <div style="margin-bottom: 15px;">
      <label style="display: block; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px;">Postal Code</label>
      <input type="text" name="address[postal_code]" style="width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem; box-sizing: border-box;">
    </div>
    <div style="margin-bottom: 20px;">
      <label style="display: block; font-size: 0.75rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 6px;">Province</label>
      <select name="address[province_id]" style="width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem; box-sizing: border-box;">
        <option value="">Select Province</option>
        <% Province.all.order(:name).each do |p| %>
          <option value="<%= p.id %>"><%= p.name %></option>
        <% end %>
      </select>
    </div>
    <button type="submit" style="padding: 12px 30px; background: #111; color: #fff; border: none; font-family: inherit; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;">Save Address</button>
  <% end %>
</div>
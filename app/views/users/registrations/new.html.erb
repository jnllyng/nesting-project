<h1>Create Account</h1>

<%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
  <%= render "devise/shared/error_messages", resource: resource %>

  <div style="margin-bottom: 20px;">
    <%= f.label :first_name, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.text_field :first_name, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :last_name, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.text_field :last_name, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :email, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.email_field :email, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :password, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.password_field :password, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 30px;">
    <%= f.label :password_confirmation, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.password_field :password_confirmation, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <%= f.submit "Sign Up", style: "padding: 12px 30px; background: #111; color: #fff; border: none; font-family: inherit; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;" %>
<% end %>

<p style="margin-top: 20px; font-size: 0.85rem;">
  Already have an account? <%= link_to "Sign in", new_session_path(resource_name), style: "color: #111;" %>
</p>
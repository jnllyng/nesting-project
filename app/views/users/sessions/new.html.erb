<h1>Log In</h1>

<%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <% if resource.errors.any? %>
  <div style="margin-bottom: 20px; padding: 12px 16px; border: 1px solid #cc0000; background: #fff5f5;">
    <% resource.errors.full_messages.each do |msg| %>
      <p style="font-size: 0.8rem; color: #cc0000; margin: 0;">← <%= msg %></p>
    <% end %>
  </div>
<% end %>

  <div style="margin-bottom: 20px;">
    <%= f.label :email, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.email_field :email, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 20px;">
    <%= f.label :password, style: "display: block; font-size: 0.8rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 8px;" %>
    <%= f.password_field :password, style: "width: 100%; padding: 10px; border: 1px solid #ddd; font-family: inherit; font-size: 0.85rem;" %>
  </div>

  <div style="margin-bottom: 30px;">
    <%= f.check_box :remember_me %>
    <%= f.label :remember_me, style: "font-size: 0.8rem;" %>
  </div>

  <%= f.submit "Log In", style: "padding: 12px 30px; background: #111; color: #fff; border: none; font-family: inherit; font-size: 0.85rem; letter-spacing: 0.1em; text-transform: uppercase; cursor: pointer;" %>
<% end %>

<p style="margin-top: 20px; font-size: 0.85rem;">
  Don't have an account? <%= link_to "Register", new_registration_path(resource_name), style: "color: #111;" %>
</p>